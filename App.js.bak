// --- MAIN APP TAB NAVIGATOR ---
const MainAppNavigator = ({ user, setIsLoggedIn }) => {
  return (
    <Tab.Navigator
      screenOptions={({ route }) => ({
        tabBarIcon: ({ focused, color, size }) => {
          let iconName;
          
          if (route.name === 'Home') { // 'Dashboard' se 'Home'
            iconName = 'home'; // 'dashboard' se 'home'
          } else if (route.name === 'Attendance') {
            iconName = 'access-time';
          } else if (route.name === 'Salary') {
            iconName = 'account-balance-wallet';
          } else if (route.name === 'Leaves') {
            iconName = 'event-available';
          }

          return <Icon name={iconName} size={size} color={color} />;
        },
        tabBarActiveTintColor: COLORS.primary,
        tabBarInactiveTintColor: COLORS.gray,
        headerShown: false, // Header ko tab navigator se hata diya
      })}
    >
      <Tab.Screen name="Home"> 
        {(props) => (
          <HomeScreen
            {...props}
            user={user}
            setIsLoggedIn={setIsLoggedIn}
          />
        )}
      </Tab.Screen>
      <Tab.Screen name="Attendance">
        {(props) => <AttendanceScreen {...props} user={user} />}
      </Tab.Screen>
      <Tab.Screen name="Salary">
        {(props) => <SalaryScreen {...props} user={user} />}
      </Tab.Screen>
      <Tab.Screen name="Leaves">
        {(props) => <LeavesScreen {...props} user={user} />}
      </Tab.Screen>
    </Tab.Navigator>
  );
};

// --- MAIN APP COMPONENT ---
const TMPVL = () => {
  const [isLoggedIn, setIsLoggedIn] = useState(false);
  const [user, setUser] = useState(null);
  const [loading, setLoading] = useState(true);

  useEffect(() => {
    checkAuthStatus();
  }, []);

  const checkAuthStatus = async () => {
    try {
      const token = await AsyncStorage.getItem('authToken');
      const userData = await AsyncStorage.getItem('userData');

      if (token && userData) {
        setUser(JSON.parse(userData));
        setIsLoggedIn(true);
        initializeSocket(JSON.parse(userData).empId);
      }
    } catch (error) {
      console.error('Auth check error:', error);
    } finally {
      setLoading(false);
    }
  };

  const initializeSocket = (empId) => {
    // socket = io('http://your-server-url:3000'); // Apna server URL yahan daalein
    // socket.emit('join', empId);
    // ... socket listeners ...
    console.log('Socket initialized for', empId);
  };

  if (loading) {
    return (
      <SafeAreaView style={styles.loadingContainer}>
        <Text style={styles.loadingText}>Loading TMPVL...</Text>
      </SafeAreaView>
    );
  }

  return (
    <NavigationContainer>
      <StatusBar backgroundColor={COLORS.primary} barStyle="light-content" />
      {isLoggedIn ? (
        <MainAppNavigator user={user} setIsLoggedIn={setIsLoggedIn} />
      ) : (
        <AuthNavigator setIsLoggedIn={setIsLoggedIn} setUser={setUser} />
      )}
    </NavigationContainer>
  );
};

