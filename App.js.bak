// TMPVL - Complete React Native App
import React, { useState, useEffect } from 'react';
import {
  View,
  Text,
  StyleSheet,
  ScrollView,
  TouchableOpacity,
  Alert,
  StatusBar,
  SafeAreaView,
  Modal,
  TextInput,
  Image,
  Dimensions,
  Platform,
} from 'react-native';
import AsyncStorage from '@react-native-async-storage/async-storage';
import { NavigationContainer } from '@react-navigation/native';
import { createBottomTabNavigator } from '@react-navigation/bottom-tabs';
import { createStackNavigator } from '@react-navigation/stack';
import Icon from 'react-native-vector-icons/MaterialIcons';
import io from 'socket.io-client';

const { width, height } = Dimensions.get('window');
const Tab = createBottomTabNavigator();
const AuthStack = createStackNavigator(); // For Login/Register
const MainStack = createStackNavigator(); // For main app (to host tabs)

// Colors
const COLORS = {
  primary: '#2563eb',
  secondary: '#1e40af',
  success: '#059669',
  danger: '#dc2626',
  warning: '#d97706',
  info: '#0891b2',
  light: '#f8fafc',
  dark: '#1e293b',
  gray: '#64748b',
  white: '#ffffff',
  background: '#f1f5f9',
};

// Socket connection
let socket = null;

// --- AUTH SCREENS ---

// 1. Login Screen
const LoginScreen = ({ navigation, setIsLoggedIn, setUser }) => {
  const [empId, setEmpId] = useState('TCS001234');
  const [password, setPassword] = useState('password123');
  const [isLoading, setIsLoading] = useState(false);

  const handleLogin = async () => {
    if (!empId || !password) {
      Alert.alert('Error', 'Please enter Employee ID and Password');
      return;
    }

    setIsLoading(true);

    try {
      // Mock login - Replace with actual API call
      const mockUser = {
        empId: 'TCS001234',
        name: 'राज कुमार शर्मा',
        department: 'IT Department',
        designation: 'Software Engineer',
        shift: 'Morning (9:00 AM - 6:00 PM)',
      };

      await AsyncStorage.setItem('authToken', 'mock-token-123');
      await AsyncStorage.setItem('userData', JSON.stringify(mockUser));

      setUser(mockUser);
      setIsLoggedIn(true);
    } catch (error) {
      Alert.alert('Login Failed', 'Please check your credentials');
    } finally {
      setIsLoading(false);
    }
  };

  return (
    <SafeAreaView style={styles.loginContainer}>
      <ScrollView
        showsVerticalScrollIndicator={false}
        contentContainerStyle={{ flexGrow: 1, justifyContent: 'center' }}
      >
        <View style={styles.loginHeader}>
          <View style={styles.logoContainer}>
            <Text style={styles.logoText}>T</Text>
          </View>
          <Text style={styles.appTitle}>TMPVL</Text>
          <Text style={styles.appSubtitle}>TATA Employee Portal</Text>
        </View>

        <View style={styles.loginForm}>
          <View style={styles.inputContainer}>
            <Icon
              name="person"
              size={20}
              color={COLORS.gray}
              style={styles.inputIcon}
            />
            <TextInput
              style={styles.textInput}
              placeholder="Employee ID"
              value={empId}
              onChangeText={setEmpId}
              autoCapitalize="characters"
            />
          </View>

          <View style={styles.inputContainer}>
            <Icon
              name="lock"
              size={20}
              color={COLORS.gray}
              style={styles.inputIcon}
            />
            <TextInput
              style={styles.textInput}
              placeholder="Password"
              value={password}
              onChangeText={setPassword}
              secureTextEntry
            />
          </View>

          <TouchableOpacity
            style={[styles.loginButton, isLoading && styles.disabledButton]}
            onPress={handleLogin}
            disabled={isLoading}
          >
            <Text style={styles.loginButtonText}>
              {isLoading ? 'Logging in...' : 'Login'}
            </Text>
          </TouchableOpacity>

          {/* NEW: Register Button */}
          <TouchableOpacity
            style={styles.registerLinkButton}
            onPress={() => navigation.navigate('Register')}
          >
            <Text style={styles.registerLinkText}>
              New user? <Text style={styles.registerLinkBold}>Register here</Text>
            </Text>
          </TouchableOpacity>
        </View>
      </ScrollView>
    </SafeAreaView>
  );
};

// 2. Register Screen
const RegisterScreen = ({ navigation }) => {
  const [name, setName] = useState('');
  const [ticketNo, setTicketNo] = useState('');
  const [mobile, setMobile] = useState('');
  const [email, setEmail] = useState('');

  const handleRegister = () => {
    // Simple validation
    if (!name || !ticketNo || !mobile || !email) {
      Alert.alert('Error', 'Please fill all fields');
      return;
    }
    if (ticketNo.length !== 6) {
      Alert.alert('Error', 'Ticket Number must be 6 digits');
      return;
    }
    if (mobile.length !== 10) {
      Alert.alert('Error', 'Mobile Number must be 10 digits');
      return;
    }
    // Mock API call and then...
    Alert.alert('Registration Sent', 'OTP sent to your mobile and email.');
    navigation.navigate('VerifyOTP', { email, mobile });
  };

  return (
    <SafeAreaView style={styles.loginContainer}>
      <ScrollView
        showsVerticalScrollIndicator={false}
        contentContainerStyle={{ paddingTop: 20 }}
      >
        <TouchableOpacity
          onPress={() => navigation.goBack()}
          style={styles.backButton}
        >
          <Icon name="arrow-back" size={24} color={COLORS.dark} />
          <Text style={styles.backButtonText}>Back to Login</Text>
        </TouchableOpacity>

        <View style={styles.loginHeader}>
          <Text style={styles.appTitle}>Create Account</Text>
          <Text style={styles.appSubtitle}>Join the TMPVL portal</Text>
        </View>

        <View style={styles.loginForm}>
          {/* Name */}
          <View style={styles.inputContainer}>
            <Icon
              name="badge"
              size={20}
              color={COLORS.gray}
              style={styles.inputIcon}
            />
            <TextInput
              style={styles.textInput}
              placeholder="Full Name"
              value={name}
              onChangeText={setName}
            />
          </View>

          {/* Ticket Number */}
          <View style={styles.inputContainer}>
            <Icon
              name="confirmation-number"
              size={20}
              color={COLORS.gray}
              style={styles.inputIcon}
            />
            <TextInput
              style={styles.textInput}
              placeholder="Ticket Number (6 digits)"
              value={ticketNo}
              onChangeText={setTicketNo}
              keyboardType="numeric"
              maxLength={6}
            />
          </View>

          {/* Mobile Number */}
          <View style={styles.inputContainer}>
            <Text style={styles.prefixText}>+91</Text>
            <TextInput
              style={[styles.textInput, { paddingLeft: 10 }]}
              placeholder="Mobile Number (10 digits)"
              value={mobile}
              onChangeText={setMobile}
              keyboardType="numeric"
              maxLength={10}
            />
          </View>

          {/* Email ID */}
          <View style={styles.inputContainer}>
            <Icon
              name="email"
              size={20}
              color={COLORS.gray}
              style={styles.inputIcon}
            />
            <TextInput
              style={styles.textInput}
              placeholder="Email ID (e.g., user@gmail.com)"
              value={email}
              onChangeText={setEmail}
              keyboardType="email-address"
              autoCapitalize="none"
            />
          </View>

          <TouchableOpacity
            style={styles.loginButton}
            onPress={handleRegister}
          >
            <Text style={styles.loginButtonText}>Register Now</Text>
          </TouchableOpacity>
        </View>
      </ScrollView>
    </SafeAreaView>
  );
};

// 3. Verify OTP Screen
const VerifyOTPScreen = ({ navigation, route }) => {
  const { email, mobile } = route.params;
  const [emailOtp, setEmailOtp] = useState('');
  const [mobileOtp, setMobileOtp] = useState('');

  const handleVerify = () => {
    if (!emailOtp || !mobileOtp) {
      Alert.alert('Error', 'Please enter both OTPs');
      return;
    }
    // Mock OTP check
    Alert.alert('Success', 'OTP Verified. Please set your password.');
    navigation.navigate('SetPassword', { email }); // Pass user identifier
  };

  return (
    <SafeAreaView style={styles.loginContainer}>
      <ScrollView
        showsVerticalScrollIndicator={false}
        contentContainerStyle={{ paddingTop: 20 }}
      >
        <TouchableOpacity
          onPress={() => navigation.goBack()}
          style={styles.backButton}
        >
          <Icon name="arrow-back" size={24} color={COLORS.dark} />
          <Text style={styles.backButtonText}>Back to Register</Text>
        </TouchableOpacity>

        <View style={styles.loginHeader}>
          <Text style={styles.appTitle}>Verify Account</Text>
          <Text style={styles.appSubtitle}>
            Enter OTP sent to {email} and {mobile}
          </Text>
        </View>

        <View style={styles.loginForm}>
          {/* Email OTP */}
          <View style={styles.inputContainer}>
            <Icon
              name="mark-email-read"
              size={20}
              color={COLORS.gray}
              style={styles.inputIcon}
            />
            <TextInput
              style={styles.textInput}
              placeholder="Email OTP"
              value={emailOtp}
              onChangeText={setEmailOtp}
              keyboardType="numeric"
              maxLength={6}
            />
          </View>

          {/* Mobile OTP */}
          <View style={styles.inputContainer}>
            <Icon
              name="sms"
              size={20}
              color={COLORS.gray}
              style={styles.inputIcon}
            />
            <TextInput
              style={styles.textInput}
              placeholder="Mobile OTP"
              value={mobileOtp}
              onChangeText={setMobileOtp}
              keyboardType="numeric"
              maxLength={6}
            />
          </View>

          <TouchableOpacity style={styles.loginButton} onPress={handleVerify}>
            <Text style={styles.loginButtonText}>Verify & Proceed</Text>
          </TouchableOpacity>
        </View>
      </ScrollView>
    </SafeAreaView>
  );
};

// 4. Set Password Screen
const SetPasswordScreen = ({ navigation, route, setIsLoggedIn, setUser }) => {
  const [password, setPassword] = useState('');
  const [confirmPassword, setConfirmPassword] = useState('');

  const handleSetPassword = async () => {
    if (!password || !confirmPassword) {
      Alert.alert('Error', 'Please fill both fields');
      return;
    }
    if (password.length < 8 || password.length > 14) {
      Alert.alert('Error', 'Password must be 8-14 characters');
      return;
    }
    if (password !== confirmPassword) {
      Alert.alert('Error', 'Passwords do not match');
      return;
    }

    // Mock final registration and login
    const mockUser = {
      empId: 'NEW_USER_001', // Should come from API
      name: 'New Registered User', // Should come from API
      ...route.params, // email
    };

    await AsyncStorage.setItem('authToken', 'mock-token-for-new-user');
    await AsyncStorage.setItem('userData', JSON.stringify(mockUser));

    setUser(mockUser);
    setIsLoggedIn(true);
    
    Alert.alert('Success', 'Registration complete. You are now logged in.');
  };

  return (
    <SafeAreaView style={styles.loginContainer}>
      <ScrollView
        showsVerticalScrollIndicator={false}
        contentContainerStyle={{ paddingTop: 20 }}
      >
        <TouchableOpacity
          onPress={() => navigation.goBack()}
          style={styles.backButton}
        >
          <Icon name="arrow-back" size={24} color={COLORS.dark} />
          <Text style={styles.backButtonText}>Back to OTP</Text>
        </TouchableOpacity>

        <View style={styles.loginHeader}>
          <Text style={styles.appTitle}>Set Password</Text>
          <Text style={styles.appSubtitle}>
            Must be 8-14 characters with upper & lower case.
          </Text>
        </View>

        <View style={styles.loginForm}>
          {/* Password */}
          <View style={styles.inputContainer}>
            <Icon
              name="lock"
              size={20}
              color={COLORS.gray}
              style={styles.inputIcon}
            />
            <TextInput
              style={styles.textInput}
              placeholder="Enter Password"
              value={password}
              onChangeText={setPassword}
              secureTextEntry
            />
          </View>

          {/* Confirm Password */}
          <View style={styles.inputContainer}>
            <Icon
              name="lock-check"
              size={20}
              color={COLORS.gray}
              style={styles.inputIcon}
            />
            <TextInput
              style={styles.textInput}
              placeholder="Confirm Password"
              value={confirmPassword}
              onChangeText={setConfirmPassword}
              secureTextEntry
            />
          </View>

          <TouchableOpacity
            style={styles.loginButton}
            onPress={handleSetPassword}
          >
            <Text style={styles.loginButtonText}>Set Password & Login</Text>
          </TouchableOpacity>
        </View>
      </ScrollView>
    </SafeAreaView>
  );
};

// --- AUTH STACK NAVIGATOR ---
const AuthNavigator = ({ setIsLoggedIn, setUser }) => (
  <AuthStack.Navigator screenOptions={{ headerShown: false }}>
    <AuthStack.Screen name="Login">
      {(props) => (
        <LoginScreen
          {...props}
          setIsLoggedIn={setIsLoggedIn}
          setUser={setUser}
        />
      )}
    </AuthStack.Screen>
    <AuthStack.Screen name="Register" component={RegisterScreen} />
    <AuthStack.Screen name="VerifyOTP" component={VerifyOTPScreen} />
    <AuthStack.Screen name="SetPassword">
      {(props) => (
        <SetPasswordScreen
          {...props}
          setIsLoggedIn={setIsLoggedIn}
          setUser={setUser}
        />
      )}
    </AuthStack.Screen>
  </AuthStack.Navigator>
);

// --- MAIN APP SCREENS ---

// 1. Home Screen (Renamed from Dashboard)
const HomeScreen = ({ user, setIsLoggedIn }) => {
  const [currentTime, setCurrentTime] = useState(
    new Date().toLocaleTimeString('en-IN'),
  );
  const [attendanceData, setAttendanceData] = useState({
    todayStatus: 'Present',
    checkIn: '09:15 AM',
    checkOut: null,
    workingHours: '7h 45m',
    thisMonth: { present: 22, absent: 2, leaves: 1 },
  });

  useEffect(() => {
    const timer = setInterval(() => {
      setCurrentTime(new Date().toLocaleTimeString('en-IN'));
    }, 1000);

    return () => clearInterval(timer);
  }, []);

  const handleLogout = async () => {
    Alert.alert('Logout', 'Are you sure you want to logout?', [
      { text: 'Cancel', style: 'cancel' },
      {
        text: 'Logout',
        onPress: async () => {
          await AsyncStorage.removeItem('authToken');
          await AsyncStorage.removeItem('userData');
          if (socket) {
            socket.disconnect();
          }
          setIsLoggedIn(false);
        },
      },
    ]);
  };

  return (
    <SafeAreaView style={styles.container}>
      <ScrollView
        style={styles.scrollContainer}
        showsVerticalScrollIndicator={false}
      >
        {/* Header */}
        <View style={styles.dashboardHeader}>
          <View style={styles.userInfo}>
            <Text style={styles.greeting}>नमस्ते, {user.name}</Text>
            <Text style={styles.designation}>{user.designation}</Text>
          </View>
          <TouchableOpacity onPress={handleLogout}>
            <Icon name="logout" size={24} color={COLORS.primary} />
          </TouchableOpacity>
        </View>

        {/* Status Card */}
        <View style={styles.statusCard}>
          <View style={styles.statusHeader}>
            <View style={styles.statusTitleRow}>
              <Icon name="access-time" size={24} color={COLORS.white} />
              <Text style={styles.statusTitle}>Today's Status</Text>
            </View>
            <View style={styles.liveIndicator}>
              <Text style={styles.liveText}>Live</Text>
            </View>
          </View>

          <View style={styles.statusContent}>
            <View style={styles.statusItem}>
              <Text style={styles.statusLabel}>Check In</Text>
              <Text style={styles.statusValue}>{attendanceData.checkIn}</Text>
            </View>
            <View style={styles.statusItem}>
              <Text style={styles.statusLabel}>Status</Text>
              <Text style={styles.statusValue}>
                {attendanceData.todayStatus}
              </Text>
            </View>
          </View>

          <View style={styles.statusFooter}>
            <Text style={styles.currentTime}>Current Time: {currentTime}</Text>
            <Text style={styles.shiftInfo}>Shift: {user.shift}</Text>
          </View>
        </View>

        {/* Quick Stats */}
        <View style={styles.quickStats}>
          <View style={styles.statCard}>
            <Icon name="event-available" size={24} color={COLORS.success} />
            <Text style={styles.statLabel}>This Month</Text>
            <Text style={styles.statValue}>
              {attendanceData.thisMonth.present} Days Present
            </Text>
          </View>

          <View style={styles.statCard}>
            <Icon
              name="account-balance-wallet"
              size={24}
              color={COLORS.primary}
            />
            <Text style={styles.statLabel}>Net Salary</Text>
            <Text style={styles.statValue}>₹59,537</Text>
          </View>
        </View>

        {/* Quick Actions */}
        <View style={styles.quickActions}>
          <Text style={styles.sectionTitle}>Quick Actions</Text>
          <View style={styles.actionGrid}>
            <TouchableOpacity style={styles.actionCard}>
              <Icon name="access-time" size={32} color={COLORS.primary} />
              <Text style={styles.actionTitle}>Attendance</Text>
              <Text style={styles.actionSubtitle}>View & Mark</Text>
            </TouchableOpacity>

            <TouchableOpacity style={styles.actionCard}>
              <Icon name="description" size={32} color={COLORS.success} />
              <Text style={styles.actionTitle}>Salary Slip</Text>
              <Text style={styles.actionSubtitle}>View & Download</Text>
            </TouchableOpacity>
          </View>
        </View>

        {/* Recent Activity */}
        <View style={styles.recentActivity}>
          <Text style={styles.sectionTitle}>Recent Activity</Text>
          <View style={styles.activityList}>
            <View style={styles.activityItem}>
              <View
                style={[styles.activityDot, { backgroundColor: COLORS.success }]}
              />
              <Text style={styles.activityText}>
                Punched In at Gate 1 - 09:15 AM
              </Text>
            </View>
            <View style={styles.activityItem}>
              <View
                style={[styles.activityDot, { backgroundColor: COLORS.primary }]}
              />
              <Text style={styles.activityText}>
                Salary slip for February generated
              </Text>
            </View>
            <View style={styles.activityItem}>
              <View
                style={[styles.activityDot, { backgroundColor: COLORS.warning }]}
              />
              <Text style={styles.activityText}>Leave request approved</Text>
            </View>
          </View>
        </View>
      </ScrollView>
    </SafeAreaView>
  );
};

